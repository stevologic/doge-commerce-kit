{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doge-spend-week.local/schemas/proof-record.json",
  "title": "DOGE Spend Week Proof Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proof_id",
    "submitted_at",
    "merchant_name",
    "merchant_url",
    "purchase_category",
    "payment_route",
    "doge_amount",
    "usd_value_at_purchase",
    "privacy_status",
    "verification_status",
    "publish_status"
  ],
  "properties": {
    "proof_id": {
      "type": "string",
      "pattern": "^doge-proof-[0-9]{4,}-[a-z0-9-]+$"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "merchant_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "merchant_url": {
      "type": "string",
      "format": "uri"
    },
    "purchase_category": {
      "type": "string",
      "enum": [
        "creator_merch",
        "digital_download",
        "game_or_server",
        "subscription",
        "gift_card_route",
        "electronics",
        "food_or_local",
        "travel",
        "service",
        "other"
      ]
    },
    "payment_route": {
      "type": "string",
      "enum": [
        "direct_doge",
        "bitpay_invoice",
        "nowpayments_invoice",
        "gigawallet_or_self_hosted",
        "gift_card_route",
        "other_processor"
      ]
    },
    "product_or_offer": {
      "type": "string",
      "maxLength": 180
    },
    "doge_amount": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "usd_value_at_purchase": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "txid_or_invoice_reference": {
      "type": "string",
      "maxLength": 180
    },
    "artifact_url_or_filename": {
      "type": "string",
      "maxLength": 240
    },
    "buyer_handle": {
      "type": "string",
      "maxLength": 80
    },
    "privacy_status": {
      "type": "string",
      "enum": [
        "clear",
        "needs_redaction",
        "do_not_publish"
      ]
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "unreviewed",
        "merchant_confirmed",
        "processor_confirmed",
        "chain_reference_confirmed",
        "rejected"
      ]
    },
    "publish_status": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "published",
        "blocked"
      ]
    },
    "notes": {
      "type": "string",
      "maxLength": 800
    }
  }
}
