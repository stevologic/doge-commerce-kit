# Copy to .env and fill in before `docker compose up -d`.
# ----------------------------------------------------------------------------

# REQUIRED. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# The container refuses to boot in production with a missing/default key.
DJANGO_SECRET_KEY=

# Canonical public domain (no scheme). Caddy obtains the Let's Encrypt
# certificate for this name and serves the app here. Set to localhost to try
# compose locally.
DOGE_DOMAIN=commerce.dog

# Alternate hostnames (space-separated) that should also be HTTPS-protected.
# Caddy gets a cert for each and 308-redirects them to DOGE_DOMAIN. Every name
# here needs an A/AAAA record pointing at this server. Leave blank to disable.
DOGE_REDIRECT_DOMAINS=www.commerce.dog doge-commerce-kit.com www.doge-commerce-kit.com

# Email Let's Encrypt uses for certificate expiry notices.
LETSENCRYPT_EMAIL=stephenabbott20@gmail.com

# Full public URL, used for canonical links, sitemap, and social previews.
DOGE_SITE_URL=https://commerce.dog

# Per-IP request limit per minute on /api/ endpoints (per gunicorn worker).
DOGE_API_RATE_LIMIT=60

# HSTS max-age in seconds (default 1 year). Set 0 to disable while testing DNS.
DJANGO_HSTS_SECONDS=31536000

# ----------------------------------------------------------------------------
# Dogecoin chain lookups. Strongly recommended for real traffic: point at a
# Blockbook-compatible indexer instead of the throttled public demo APIs.
DOGE_BLOCKBOOK_BASE_URL=
DOGE_BLOCKBOOK_API_KEY=
DOGE_BLOCKBOOK_API_KEY_HEADER=api-key
DOGE_BLOCKCHAIN_PROVIDER_NAME=Dedicated Dogecoin indexer
DOGE_ENABLE_BLOCKCYPHER_FALLBACK=true
DOGE_LOOKUP_CACHE_TTL=90
# Short cache used only while an active POS payment is being detected/verified.
DOGE_PAYMENT_POLL_CACHE_TTL=5
