# Caddy terminates TLS with automatic Let's Encrypt certificates for
# commerce.dog and proxies everything to the Django/gunicorn container.
#
# Override DOGE_DOMAIN=localhost in .env to try compose locally — Caddy then
# issues a local self-signed certificate instead of contacting Let's Encrypt.
{
	email {$LETSENCRYPT_EMAIL}
}

{$DOGE_DOMAIN:commerce.dog} {
	encode zstd gzip

	reverse_proxy web:42069

	header {
		# Django sets HSTS, nosniff, referrer-policy, and frame options;
		# just make sure the server identity stays quiet.
		-Server
	}
}
